{
  "$schema": "https://schemas.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capability: file I/O, dialogs, shell access for export",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "shell:allow-open"
  ]
}
