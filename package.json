{
  "name": "mermaid-visual-editor",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "cargo run -p mermaid-visual-editor-server -- --dev --port 3001",
    "build:server": "cargo build -p mermaid-visual-editor-server --release"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xyflow/react": "^12",
    "mermaid": "^11",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^4.1.0"
  }
}
